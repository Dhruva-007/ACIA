# Firebase Project Configuration
FIREBASE_PROJECT_ID=acia-carbon-assistant

# Google Application Credentials
# Path to your service account key JSON file
# For local development: path to downloaded service account key
# For Cloud Run: not needed (uses attached service account)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Vertex AI Configuration
VERTEX_AI_PROJECT_ID=acia-carbon-assistant
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Application Settings
ENVIRONMENT=development
DEBUG=false

# Rate Limiting
RATE_LIMIT_AI_PER_HOUR=20
RATE_LIMIT_API_PER_MINUTE=100